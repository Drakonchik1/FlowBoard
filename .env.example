# Copy this file to .env and replace values. .env is git-ignored — never commit it.
MSSQL_SA_PASSWORD=YOUR_STRONG_SA_PASSWORD_HERE
JWT_SECRET_KEY=REPLACE_WITH_AT_LEAST_32_RANDOM_CHARACTERS

# Cursor SDK — agent-runner only (scripts/run-next-task.ps1). Not used by the API.
# Mint at Cursor Dashboard → API Keys: https://cursor.com/dashboard
CURSOR_API_KEY=

# Redis (Sprint 5 — SignalR backplane).
# docker compose up: API gets ConnectionStrings__Redis=redis:6379 automatically (no .env entry needed).
# Local dotnet run against compose Redis on the host:
REDIS_CONNECTION=localhost:6379

# Integration tests (optional — scripts/run-integration-tests.ps1 -UseCompose)
# Default password when unset: FlowBoard_Integration_Test1!
# MSSQL_SA_PASSWORD=YOUR_STRONG_SA_PASSWORD_HERE
